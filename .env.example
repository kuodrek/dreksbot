# Required: Discord bot token (from Discord Developer Portal)
export DISCORD_TOKEN=your_bot_token_here

# Required: Discord Application ID (from Discord Developer Portal > General Information)
export DISCORD_APP_ID=your_app_id_here

# Optional: Guild ID for instant command registration during development.
# Leave empty to register commands globally (takes up to 1 hour to propagate).
export DEV_GUILD_ID=your_test_server_id_here

# Optional: EC2 host for scripts/upload-cookies.sh
export EC2_HOST=your_ec2_host_here
